{
  "name": "sass-asm-syntax",
  "displayName": "SASS Assembly Syntax",
  "description": "Syntax highlighting, snippets and assembler integration for SASS (Simple CPU Assembler)",
  "version": "2.0.0",
  "publisher": "simple-cpu",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "assembly",
    "assembler",
    "sass",
    "cpu",
    "verilog"
  ],
  "activationEvents": [
    "onLanguage:sass-asm"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "sass-asm",
        "aliases": [
          "SASS Assembly",
          "sass-asm"
        ],
        "extensions": [
          ".asm"
        ],
        "configuration": "./language-configuration/language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "sass-asm",
        "scopeName": "source.sass-asm",
        "path": "./syntaxes/sass-asm.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "sass-asm",
        "path": "./snippets/sass-asm.json"
      }
    ],
    "commands": [
      {
        "command": "sass-asm.compile",
        "title": "Compile",
        "icon": "$(play)"
      },
      {
        "command": "sass-asm.compilePrint",
        "title": "Compile (Print Mode)",
        "icon": "$(output)"
      },
      {
        "command": "sass-asm.compileDebug",
        "title": "Compile (Debug Mode)",
        "icon": "$(bug)"
      },
      {
        "command": "sass-asm.selectCompileMode",
        "title": "Select Compile Mode",
        "icon": "$(chevron-down)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceExtname == .asm",
          "command": "sass-asm.compile",
          "group": "navigation@1"
        },
        {
          "when": "resourceExtname == .asm",
          "command": "sass-asm.selectCompileMode",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "title": "SASS Assembler",
      "properties": {
        "sass-asm.outputFormat": {
          "type": "string",
          "default": "verilog",
          "enum": [
            "verilog",
            "coe",
            "mif",
            "hex",
            "bin"
          ],
          "enumDescriptions": [
            "Verilog module (.v)",
            "Xilinx COE file (.coe)",
            "Altera MIF file (.mif)",
            "Intel HEX file (.hex)",
            "Binary file (.bin)"
          ],
          "description": "Default output format for the assembler"
        },
        "sass-asm.outputPath": {
          "type": "string",
          "default": "",
          "description": "Custom output directory (leave empty to use same directory as source file)"
        }
      }
    }
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vscode": "^1.74.0",
    "typescript": "^6.0.3"
  }
}
