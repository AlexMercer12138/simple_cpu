{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MERC32 Assembly",
  "scopeName": "source.merc32-asm",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#conditions"
    },
    {
      "include": "#characters"
    },
    {
      "include": "#registers"
    },
    {
      "include": "#immediates"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.merc32-asm",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.merc32-asm",
          "match": "//.*$"
        }
      ]
    },
    "conditions": {
      "patterns": [
        {
          "name": "variable.parameter.condition.merc32-asm",
          "match": "\"(?:==|!=|<=|>=|<|>|eq|ne|ge|lt|gt|le|sge|slt|sgt|sle|uge|ult|ugt|ule)\""
        }
      ]
    },
    "characters": {
      "patterns": [
        {
          "name": "string.quoted.double.character.merc32-asm",
          "match": "\"(?:\\\\(?:[nrt0\"\\\\]|x[0-9a-fA-F]{2})|[^\"\\\\]){1,2}\""
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.directive.merc32-asm",
          "match": "\\.(equ|prog|entry|ifdef|elsif|else|endif|macro|endm|include|rept|endr)\\b"
        },
        {
          "name": "keyword.control.instruction.merc32-asm",
          "match": "\\b(mov|cmp|jmp|brc|brcu)\\b"
        }
      ]
    },
    "registers": {
      "patterns": [
        {
          "name": "variable.other.register.merc32-asm",
          "match": "\\br(?:1[0-5]|[0-9])\\b"
        }
      ]
    },
    "immediates": {
      "patterns": [
        {
          "name": "constant.numeric.hex.merc32-asm",
          "match": "(?<![A-Za-z0-9_])-?0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.merc32-asm",
          "match": "(?<![A-Za-z0-9_])-?0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.decimal.merc32-asm",
          "match": "(?<![A-Za-z0-9_])-?[0-9]+\\b"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.brackets.square.merc32-asm",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.brackets.round.merc32-asm",
          "match": "[()]"
        }
      ]
    }
  }
}
