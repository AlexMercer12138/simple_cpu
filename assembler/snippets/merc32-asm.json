{
  "mov": {
    "prefix": "mov",
    "body": [
      "mov ${1:r1}, ${2:0}"
    ],
    "description": "mov instruction"
  },
  "load": {
    "prefix": "load",
    "body": [
      "mov ${1:r1}, [${2:r0} + ${3:0}]"
    ],
    "description": "load from memory"
  },
  "store": {
    "prefix": "store",
    "body": [
      "mov [${1:r0} + ${2:0}], ${3:r1}"
    ],
    "description": "store to memory"
  },
  "jmp": {
    "prefix": "jmp",
    "body": [
      "jmp ${1:target}, ${2:r15}"
    ],
    "description": "jump to target"
  },
  "brc": {
    "prefix": "brc",
    "body": [
      "brc ${1:target}, ${2:r1} ${3|==,!=,<,>=|} ${4:r0}"
    ],
    "description": "conditional branch"
  },
  "label": {
    "prefix": "label",
    "body": [
      "${1:label}:"
    ],
    "description": "label definition"
  },
  ".prog": {
    "prefix": [
      ".prog",
      "prog"
    ],
    "body": [
      ".prog ${1:program_name}"
    ],
    "description": "program output name"
  },
  ".equ": {
    "prefix": [
      ".equ",
      "equ"
    ],
    "body": [
      ".equ ${1:name} ${2:value}"
    ],
    "description": "constant macro definition"
  },
  ".equ symbol": {
    "prefix": [
      ".equdef",
      "equdef"
    ],
    "body": [
      ".equ ${1:symbol}"
    ],
    "description": "symbol-only macro definition"
  },
  ".ifdef": {
    "prefix": [
      ".ifdef",
      "ifdef"
    ],
    "body": [
      ".ifdef ${1:symbol}",
      "    ${2:mov r1, 0}",
      ".endif"
    ],
    "description": "conditional compilation block"
  },
  ".ifelse": {
    "prefix": [
      ".ifelse",
      "ifelse"
    ],
    "body": [
      ".ifdef ${1:symbol}",
      "    ${2:mov r1, 0}",
      ".else",
      "    ${3:mov r1, 1}",
      ".endif"
    ],
    "description": "conditional compilation block with else"
  },
  ".elsif": {
    "prefix": [
      ".elsif",
      "elsif"
    ],
    "body": [
      ".elsif ${1:symbol}"
    ],
    "description": "conditional compilation else-if branch"
  },
  ".macro": {
    "prefix": [
      ".macro",
      "macro"
    ],
    "body": [
      ".macro ${1:name}(${2:rd, value})",
      "    ${3:mov rd, value}",
      ".endm"
    ],
    "description": "parameterized code macro"
  },
  ".include": {
    "prefix": [
      ".include",
      "include"
    ],
    "body": [
      ".include \"${1:file.asm}\""
    ],
    "description": "include another assembly file"
  },
  ".rept": {
    "prefix": [
      ".rept",
      "rept"
    ],
    "body": [
      ".rept ${1:count}",
      "    ${2:mov r1, 0}",
      ".endr"
    ],
    "description": "repeat code block"
  }
}
