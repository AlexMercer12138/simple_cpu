{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "MERC32 Assembly",
  "scopeName": "source.merc32-asm",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#labels"
    },
    {
      "include": "#instructions"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.merc32-asm",
          "begin": "/\\*",
          "end": "\\*/"
        },
        {
          "name": "comment.line.double-slash.merc32-asm",
          "match": "//.*$"
        }
      ]
    },
    "labels": {
      "patterns": [
        {
          "name": "entity.name.label.merc32-asm",
          "match": "^[\\s\\t]*([a-zA-Z_][a-zA-Z0-9_]*)\\s*:",
          "captures": {
            "1": {
              "name": "entity.name.label.merc32-asm"
            }
          }
        }
      ]
    },
    "instructions": {
      "patterns": [
        {
          "include": "#mov-instruction"
        },
        {
          "include": "#jmp-instruction"
        },
        {
          "include": "#brc-instruction"
        }
      ]
    },
    "mov-instruction": {
      "patterns": [
        {
          "name": "meta.instruction.mov.merc32-asm",
          "begin": "\\b(MOV)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.mov.merc32-asm"
            }
          },
          "end": "(?=//)|(?=/\\*)|$",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#memory-access"
            },
            {
              "include": "#alu-operation"
            },
            {
              "include": "#operands"
            }
          ]
        }
      ]
    },
    "jmp-instruction": {
      "patterns": [
        {
          "name": "meta.instruction.jmp.merc32-asm",
          "begin": "\\b(JMP)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.jmp.merc32-asm"
            }
          },
          "end": "(?=//)|(?=/\\*)|$",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#operands"
            }
          ]
        }
      ]
    },
    "brc-instruction": {
      "patterns": [
        {
          "name": "meta.instruction.brc.merc32-asm",
          "begin": "\\b(BRC)\\b",
          "beginCaptures": {
            "1": {
              "name": "keyword.control.brc.merc32-asm"
            }
          },
          "end": "(?=//)|(?=/\\*)|$",
          "patterns": [
            {
              "include": "#comments"
            },
            {
              "include": "#brc-operands"
            }
          ]
        }
      ]
    },
    "brc-operands": {
      "patterns": [
        {
          "match": "(R1[0-5]|R[0-9])\\s*,\\s*(R1[0-5]|R[0-9])\\s*(==|!=|<|>=)\\s*(R1[0-5]|R[0-9])",
          "captures": {
            "1": {
              "name": "variable.other.register.merc32-asm"
            },
            "2": {
              "name": "variable.other.register.merc32-asm"
            },
            "3": {
              "name": "keyword.operator.comparison.merc32-asm"
            },
            "4": {
              "name": "variable.other.register.merc32-asm"
            }
          }
        },
        {
          "match": "(0[xX][0-9a-fA-F]+|0[bB][01]+|-?[0-9]+)\\s*,\\s*(R1[0-5]|R[0-9])\\s*(==|!=|<|>=)\\s*(R1[0-5]|R[0-9])",
          "captures": {
            "1": {
              "name": "constant.numeric.immediate.merc32-asm"
            },
            "2": {
              "name": "variable.other.register.merc32-asm"
            },
            "3": {
              "name": "keyword.operator.comparison.merc32-asm"
            },
            "4": {
              "name": "variable.other.register.merc32-asm"
            }
          }
        },
        {
          "match": "([a-zA-Z_][a-zA-Z0-9_]*)\\s*,\\s*(R1[0-5]|R[0-9])\\s*(==|!=|<|>=)\\s*(R1[0-5]|R[0-9])",
          "captures": {
            "1": {
              "name": "entity.name.label.merc32-asm"
            },
            "2": {
              "name": "variable.other.register.merc32-asm"
            },
            "3": {
              "name": "keyword.operator.comparison.merc32-asm"
            },
            "4": {
              "name": "variable.other.register.merc32-asm"
            }
          }
        }
      ]
    },
    "memory-access": {
      "patterns": [
        {
          "name": "meta.memory-access.merc32-asm",
          "match": "\\[\\s*(R1[0-5]|R[0-9])\\s*(?:\\+\\s*(R1[0-5]|R[0-9]))?\\s*\\]",
          "captures": {
            "1": {
              "name": "variable.other.register.merc32-asm"
            },
            "2": {
              "name": "variable.other.register.merc32-asm"
            }
          }
        },
        {
          "name": "meta.memory-access.merc32-asm",
          "match": "\\[\\s*(R1[0-5]|R[0-9])\\s*(?:\\+\\s*(0[xX][0-9a-fA-F]+|0[bB][01]+|-?[0-9]+))?\\s*\\]",
          "captures": {
            "1": {
              "name": "variable.other.register.merc32-asm"
            },
            "2": {
              "name": "constant.numeric.immediate.merc32-asm"
            }
          }
        }
      ]
    },
    "alu-operation": {
      "patterns": [
        {
          "name": "meta.alu-operation.merc32-asm",
          "match": "(R1[0-5]|R[0-9])\\s*(\\+|\\-|&|\\||\\^|<<|>>|>>>)\\s*(0[xX][0-9a-fA-F]+|0[bB][01]+|-?[0-9]+)",
          "captures": {
            "1": {
              "name": "variable.other.register.merc32-asm"
            },
            "2": {
              "name": "keyword.operator.arithmetic.merc32-asm"
            },
            "3": {
              "name": "constant.numeric.immediate.merc32-asm"
            }
          }
        },
        {
          "name": "meta.alu-operation.merc32-asm",
          "match": "(R1[0-5]|R[0-9])\\s*(\\+|\\-|&|\\||\\^|<<|>>|>>>)\\s*(R1[0-5]|R[0-9])",
          "captures": {
            "1": {
              "name": "variable.other.register.merc32-asm"
            },
            "2": {
              "name": "keyword.operator.arithmetic.merc32-asm"
            },
            "3": {
              "name": "variable.other.register.merc32-asm"
            }
          }
        }
      ]
    },
    "operands": {
      "patterns": [
        {
          "name": "variable.other.register.merc32-asm",
          "match": "\\bR1[0-5]\\b"
        },
        {
          "name": "variable.other.register.merc32-asm",
          "match": "\\bR[0-9]\\b"
        },
        {
          "name": "constant.numeric.hex.merc32-asm",
          "match": "\\b0[xX][0-9a-fA-F]+\\b"
        },
        {
          "name": "constant.numeric.binary.merc32-asm",
          "match": "\\b0[bB][01]+\\b"
        },
        {
          "name": "constant.numeric.immediate.merc32-asm",
          "match": "\\b-?[0-9]+\\b"
        },
        {
          "name": "entity.name.label.merc32-asm",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "punctuation.separator.comma.merc32-asm",
          "match": ","
        }
      ]
    }
  }
}
